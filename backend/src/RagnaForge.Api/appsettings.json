{
  "RagnaForge": {
    "Agent": {
      "AgentExePath": "ragnaforge.exe",
      "AgentCacheDir": "cache/agent",
      "AgentTimeoutSeconds": 30
    },
    "Api": {
      "ReadOnlyMode": true,
      "EnableApplyEndpoints": false,
      "EnableRollbackEndpoints": false,
      "RequireApiKey": true,
      "AllowDevelopmentWithoutApiKey": false,
      "ApiKeyHeaderName": "X-RagnaForge-Api-Key",
      "AllowedOrigins": [
        "http://127.0.0.1:5173",
        "http://localhost:5173"
      ],
      "MaxRequestBodyBytes": 1048576,
      "MaxGrfContainersPerRequest": 50,
      "MaxDiffHunksPerResponse": 500,
      "MaxScanSeconds": 60,
      "GlobalRequestsPerMinute": 60,
      "GrfRequestsPerMinute": 5,
      "MapRequestsPerMinute": 10,
      "HeavyOperationConcurrency": 2,
      "IncludeExceptionDetails": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
